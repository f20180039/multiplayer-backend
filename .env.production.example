PORT=4000
NODE_ENV=production
REDIS_URL=rediss://default:PASSWORD@your-redis-host:6379
USE_IN_MEMORY_REDIS=false
CORS_ORIGIN=https://your-frontend-domain.com
FIREBASE_PROJECT_ID=your-firebase-project-id

# Choose one Firebase Admin credential style.
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-firebase-project-id"}
